// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

// --- ตาราง User ---
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?

  // 🟢 1. เปลี่ยนค่าเริ่มต้นเป็น 0 ป้องกันการสมัครปุ๊บได้ปั๊บ
  coinBalance Int @default(0)

  // 🟢 2. เพิ่มตัวแปรเช็คว่าเคยกดรับสิทธิ์ฟรี 50 Coins ไปหรือยัง
  hasClaimedFreeCoins Boolean @default(false)

  role Role @default(USER)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  accounts  Account[]
  sessions  Session[]

  transactions    Transaction[]
  generatedAssets GeneratedAsset[]
}

model GeneratedAsset {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String // "IMAGE", "VIDEO", หรือ "PROMPT"
  prompt      String   @db.Text
  category    String?
  outputUrl   String   @db.Text
  aspectRatio String?
  createdAt   DateTime @default(now())

  @@index([userId])
}

enum TransactionType {
  TOPUP
  SPEND_IMAGE
  SPEND_VIDEO
  SPEND_PROMPT
  REFUND
  FREE_BONUS // 🟢 เพิ่มประเภทแจกฟรี เพื่อให้รู้ว่าเหรียญมาจากไหน
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Transaction {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         TransactionType
  amount       Int
  balanceAfter Int
  description  String?
  referenceId  String?           @unique
  status       TransactionStatus @default(COMPLETED)
  createdAt    DateTime          @default(now())
}

// 🟢 3. เพิ่มตารางจำรหัสอุปกรณ์ (กันปั๊มบัญชี)
model DeviceFingerprint {
  id        String   @id @default(cuid())
  visitorId String   @unique // รหัสประจำเครื่อง (จาก FingerprintJS)
  userId    String // ใครเป็นคนใช้เครื่องนี้กดรับไป
  createdAt DateTime @default(now())
}
