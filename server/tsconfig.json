{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "ignoreDeprecations": "6.0",
    "rootDir": "./src",
    
    // สำคัญมาก: เปิดตัวนี้เพื่อให้เราใช้ import library เก่าๆ ของ Node ได้ง่าย
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    // คงความเข้มงวดไว้เพื่อความปลอดภัยของโค้ด
    "strict": true,
    "skipLibCheck": true,
    
    // ตั้งค่าสำหรับการใช้งาน Node.js
    "types": ["node", "express"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}